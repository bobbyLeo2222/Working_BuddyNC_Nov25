{
  "name": "sg-papers-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "preview": "npm run preview --workspace client",
    "lint": "npm run lint --workspace client",
    "server": "npm run dev --workspace server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": { "node": "20.x", "npm": "11.6.2" },
  "packageManager": "npm@11.6.2",
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@^4.21.0"
  }
}
